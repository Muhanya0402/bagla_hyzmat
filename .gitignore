# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ── SECRETS: signing keys + keystore passwords ────────────────────────────
# НИКОГДА не коммитить — приватный ключ должен быть только локально / в CI.
android/key.properties
android/app/*.jks
android/app/*.keystore
ios/*.p12
ios/Runner/GoogleService-Info.plist

# Symbol files для деобфускации release crash-stack'ов — также секретны
# (можно по ним восстановить логику кода).
build/symbols/

